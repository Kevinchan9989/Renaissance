{
  "projectName": "Renaissance DM Tool",
  "description": "Data Migration Tool for MAS Securities - OMEGA Project (Oracle to PostgreSQL migration)",
  "version": "1.0.0",
  "techStack": {
    "framework": "React 18.2.0",
    "language": "TypeScript 5.3.0",
    "buildTool": "Vite 5.0.0",
    "desktop": "Electron 28.3.3 (optional - for desktop builds)",
    "runtime": "Node.js"
  },
  "dependencies": {
    "core": {
      "react": "^18.2.0",
      "react-dom": "^18.2.0"
    },
    "visualization": {
      "konva": "^9.3.6",
      "react-konva": "^18.2.10",
      "@dagrejs/dagre": "^1.1.2",
      "elkjs": "^0.11.0"
    },
    "ui": {
      "lucide-react": "^0.365.0",
      "prismjs": "^1.30.0",
      "@types/prismjs": "^1.26.5",
      "react-simple-code-editor": "^0.14.1"
    },
    "export": {
      "exceljs": "^4.4.0"
    }
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "viteConfig": {
    "plugins": ["@vitejs/plugin-react"],
    "server": {
      "port": 3000,
      "host": "0.0.0.0"
    },
    "base": "./"
  },
  "tsConfig": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "fileStructure": {
    "src/": {
      "App.tsx": "Root application component - manages scripts, views, theme, sidebar",
      "main.tsx": "React entry point with global error handlers",
      "types/": {
        "index.ts": "All TypeScript interfaces and type definitions",
        "electron.d.ts": "Electron IPC type declarations (optional for web-only)"
      },
      "components/": {
        "DataDictionary.tsx": "CORE: Data dictionary view with Excel-like editing (4591 lines)",
        "Sidebar.tsx": "Navigation sidebar with table list and mapping tree (541 lines)",
        "ScriptManager.tsx": "Script CRUD, versioning, import/export (1117 lines)",
        "SchemaCompare.tsx": "Side-by-side schema comparison (970 lines)",
        "ERDViewer.tsx": "Entity Relationship Diagram canvas (2132 lines)",
        "ERDExportPreview.tsx": "ERD export preview dialog",
        "ColumnMapper/ColumnMapper.tsx": "Visual column mapping canvas with Konva (6016 lines)",
        "ColumnMapper/index.ts": "Barrel export",
        "FlowchartViewer.tsx": "PlantUML activity diagram renderer",
        "CodeEditor.tsx": "Syntax-highlighted code editor with PrismJS",
        "DDLDiffView.tsx": "DDL diff visualization",
        "ExcelExportPreview.tsx": "Excel export preview dialog",
        "SearchOverlay.tsx": "Global search overlay (Ctrl+F)",
        "SettingsModal.tsx": "Theme and sync settings",
        "BackupSettings.tsx": "Backup/restore configuration",
        "CreateScriptModal.tsx": "New script creation dialog",
        "AttachSampleDataModal.tsx": "CSV sample data attachment",
        "ImportDDLModal.tsx": "DDL import dialog",
        "ImportTablesModal.tsx": "Table import dialog",
        "ImportExplanationsModal.tsx": "Explanation import dialog",
        "ImportTableDescriptionsModal.tsx": "Table description import",
        "ImportMasterCodeModal.tsx": "Master code import dialog",
        "ImportMasterCodeCategoryModal.tsx": "Master code category import",
        "versioning/": {
          "VersionBadge.tsx": "Version number badge",
          "VersionHistory.tsx": "Version history list",
          "VersionHistoryPopup.tsx": "Version history popup dialog",
          "VersionCompare.tsx": "Version comparison view",
          "VersionMinimap.tsx": "Minimap for version diffs",
          "index.ts": "Barrel exports"
        }
      },
      "utils/": {
        "storage.ts": "LocalStorage persistence, workspace import/export, git sync",
        "parsers.ts": "DDL parsers for PostgreSQL, Oracle, DBML, PlantUML (1447 lines)",
        "ddlGenerator.ts": "Generate DDL from Table objects (578 lines)",
        "compare.ts": "Schema comparison algorithms (258 lines)",
        "mapping.ts": "Column mapping logic and validation (577 lines)",
        "excelExport.ts": "ExcelJS export with formatting (642 lines)",
        "sqlAlignment.ts": "SQL alignment script generation",
        "versionDiff.ts": "Version diff computation",
        "sampleDataParser.ts": "CSV parsing and table matching",
        "debugLogger.ts": "Debug logging utility"
      },
      "services/": {
        "electronStorage.ts": "Electron IPC file operations (optional)",
        "googleDriveSync.ts": "Google Drive sync (optional)",
        "backupManager.ts": "Backup/restore logic",
        "localBackup.ts": "Local filesystem backups"
      },
      "constants/": {
        "typeMatrix.ts": "Type compatibility rules (Oracle<->PostgreSQL)",
        "erd.ts": "ERD visualization constants",
        "flowchart.ts": "Flowchart rendering constants",
        "vscodeTheme.ts": "VS Code color theme definitions"
      },
      "config/": {
        "googleDrive.config.ts": "Google Drive OAuth config (optional)"
      },
      "styles/": {
        "index.css": "Main CSS (5097 lines) - all layouts, dark theme, components",
        "codeEditor.css": "Syntax highlighting CSS variables",
        "versioning.css": "Version history UI styles"
      }
    }
  },
  "storageKeys": {
    "dm_tool_data": "Scripts array (main data)",
    "dm_tool_theme": "Theme: light | dark",
    "dm_tool_theme_variant": "Dark variant: slate | vscode-gray",
    "dm_tool_mapping_projects": "Mapping projects array",
    "dm_tool_type_rule_sets": "Custom type compatibility rule sets",
    "dm_tool_mapping_workspace": "Mapping canvas workspace state",
    "dm_flowchart_scripts": "Flowchart scripts array",
    "dm_tool_script_order": "Custom script ordering",
    "dd_visible_columns": "Data dictionary visible columns",
    "dd_column_widths": "Data dictionary column widths per script",
    "erd_positions_{scriptId}": "ERD node positions per script"
  },
  "notes": {
    "electronOptional": "The app works as a pure web app with localStorage. Electron is only needed for desktop file system access. For GSIB/Coder, use web-only mode.",
    "noBackendRequired": "This is a fully client-side application. No API server needed.",
    "dataStorage": "All data persisted in browser localStorage. Workspace can be exported/imported as JSON."
  }
}
