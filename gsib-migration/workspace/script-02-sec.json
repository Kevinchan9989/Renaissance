  "rawContent": "-- sec.sec_security_master definition\n\n-- Drop table\n\n-- DROP TABLE sec.sec_security_master;\n\nCREATE TABLE sec.sec_security_master (\n\tid int8 NOT NULL GENERATED BY DEFAULT AS IDENTITY( INCREMENT BY 1 MINVALUE 1 MAXVALUE 9223372036854775807 START 150000000000001 CACHE 1 NO CYCLE),\n\t\"uuid\" varchar(36) NOT NULL DEFAULT gen_random_uuid(),\n\tisin_code varchar(12) NULL,\n\tissue_code varchar(8) NULL,\n\tissue_desc varchar(30) NULL,\n\ttax_status bpchar(1) NULL,\n\tetender_ind bpchar(1) NULL,\n\tcurrency bpchar(3) NULL,\n\tsgs_type varchar(20) NULL,\n\tfirst_coupon_payment_dt timestamp NULL,\n\tcoupon_pay_frequency varchar(20) NULL,\n\t\"version\" numeric(5) NOT NULL,\n\tis_deleted bpchar(1) NOT NULL,\n\tis_migrated bpchar(1) NOT NULL,\n\tcreated_dt timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP,\n\tcreated_by varchar(36) NOT NULL,\n\tupdated_dt timestamp NOT NULL,\n\tupdated_by varchar(36) NOT NULL,\n\tCONSTRAINT sec_security_master_isin_code_key UNIQUE (isin_code),\n\tCONSTRAINT sec_security_master_issue_code_key UNIQUE (issue_code),\n\tCONSTRAINT sec_security_master_pkey PRIMARY KEY (id),\n\tCONSTRAINT sec_security_master_uuid_key UNIQUE (uuid)\n);\n\n\n-- sec.sec_coupon_schedule definition\n\n-- Drop table\n\n-- DROP TABLE sec.sec_coupon_schedule;\n\nCREATE TABLE sec.sec_coupon_schedule (\n\tid int8 NOT NULL GENERATED BY DEFAULT AS IDENTITY( INCREMENT BY 1 MINVALUE 1 MAXVALUE 9223372036854775807 START 150000000000001 CACHE 1 NO CYCLE),\n\t\"uuid\" varchar(36) NOT NULL DEFAULT gen_random_uuid(),\n\tsec_security_master_id varchar(36) NOT NULL,\n\tcoupon_index numeric(2) NOT NULL,\n\tcoupon_payment_dt timestamp NOT NULL,\n\t\"version\" numeric(5) NOT NULL,\n\tis_deleted bpchar(1) NOT NULL,\n\tis_migrated bpchar(1) NOT NULL,\n\tcreated_dt timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP,\n\tcreated_by varchar(36) NOT NULL,\n\tupdated_dt timestamp NOT NULL,\n\tupdated_by varchar(36) NOT NULL,\n\tCONSTRAINT sec_coupon_schedule_pkey PRIMARY KEY (id),\n\tCONSTRAINT sec_coupon_schedule_uuid_key UNIQUE (uuid),\n\tCONSTRAINT fk_coupon_schedule_master FOREIGN KEY (sec_security_master_id) REFERENCES sec.sec_security_master(\"uuid\")\n);\n\n\n-- sec.sec_coupon_schedule_t definition\n\n-- Drop table\n\n-- DROP TABLE sec.sec_coupon_schedule_t;\n\nCREATE TABLE sec.sec_coupon_schedule_t (\n\ttrans_id int8 NOT NULL GENERATED BY DEFAULT AS IDENTITY( INCREMENT BY 1 MINVALUE 1 MAXVALUE 9223372036854775807 START 150000000000001 CACHE 1 NO CYCLE),\n\ttrans_uuid varchar(36) NOT NULL DEFAULT gen_random_uuid(),\n\tid int8 NOT NULL,\n\t\"uuid\" varchar(36) NOT NULL,\n\tsec_security_master_id varchar(36) NOT NULL,\n\tcoupon_index numeric(2) NOT NULL,\n\tcoupon_payment_dt timestamp NOT NULL,\n\t\"version\" numeric(5) NOT NULL,\n\tis_deleted bpchar(1) NOT NULL,\n\tis_migrated bpchar(1) NOT NULL,\n\tcreated_dt timestamp NOT NULL,\n\tcreated_by varchar(36) NOT NULL,\n\tupdated_dt timestamp NOT NULL,\n\tupdated_by varchar(36) NOT NULL,\n\taudit_action bpchar(1) NOT NULL,\n\taudit_timestamp timestamp NULL DEFAULT CURRENT_TIMESTAMP,\n\tis_history bpchar(1) NOT NULL DEFAULT 'Y'::bpchar,\n\tCONSTRAINT sec_coupon_schedule_h_hist_uuid_key UNIQUE (trans_uuid),\n\tCONSTRAINT sec_coupon_schedule_h_pkey PRIMARY KEY (trans_id),\n\tCONSTRAINT fk_coupon_schedule_t_master FOREIGN KEY (\"uuid\") REFERENCES sec.sec_coupon_schedule(\"uuid\")\n);\n\n\n-- sec.sec_security_master_t definition\n\n-- Drop table\n\n-- DROP TABLE sec.sec_security_master_t;\n\nCREATE TABLE sec.sec_security_master_t (\n\ttrans_id int8 NOT NULL GENERATED BY DEFAULT AS IDENTITY( INCREMENT BY 1 MINVALUE 1 MAXVALUE 9223372036854775807 START 150000000000001 CACHE 1 NO CYCLE),\n\ttrans_uuid varchar(36) NOT NULL DEFAULT gen_random_uuid(),\n\tid int8 NOT NULL,\n\t\"uuid\" varchar(36) NOT NULL,\n\tisin_code varchar(12) NOT NULL,\n\tissue_code varchar(8) NOT NULL,\n\tissue_desc varchar(30) NULL,\n\ttax_status bpchar(1) NULL,\n\tetender_ind bpchar(1) NULL,\n\tcurrency bpchar(3) NULL,\n\tsgs_type varchar(20) NULL,\n\tfirst_coupon_payment_dt timestamp NULL,\n\tcoupon_pay_frequency varchar(20) NULL,\n\t\"version\" numeric(5) NOT NULL,\n\tis_deleted bpchar(1) NOT NULL,\n\tis_migrated bpchar(1) NOT NULL,\n\tcreated_dt timestamp NOT NULL,\n\tcreated_by varchar(36) NOT NULL,\n\tupdated_dt timestamp NOT NULL,\n\tupdated_by varchar(36) NOT NULL,\n\taudit_action bpchar(1) NOT NULL,\n\taudit_timestamp timestamp NULL DEFAULT CURRENT_TIMESTAMP,\n\tis_history bpchar(1) NOT NULL DEFAULT 'Y'::bpchar,\n\tCONSTRAINT sec_security_master_h_hist_uuid_key UNIQUE (trans_uuid),\n\tCONSTRAINT sec_security_master_h_pkey PRIMARY KEY (trans_id),\n\tCONSTRAINT fk_security_master_t_master FOREIGN KEY (\"uuid\") REFERENCES sec.sec_security_master(\"uuid\")\n);",
