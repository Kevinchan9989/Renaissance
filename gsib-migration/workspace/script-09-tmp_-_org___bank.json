  "name": "tmp - org & bank",
  "type": "postgresql",
  "createdAt": 1768289772110,
  "updatedAt": 1768467558146,
  "rawContent": "-- =========================================================================\n-- 1. CM_BANK_MASTER\n-- Purpose: The \"Raw\" Source of Truth from Daily Interface (banks.txt).\n-- Contains STRICTLY the 5 columns defined in the interface spec.\n-- =========================================================================\n\nCREATE TABLE cm.cm_bank_master (\n    id int8 NOT NULL GENERATED BY DEFAULT AS IDENTITY( INCREMENT BY 1 MINVALUE 1 MAXVALUE 9223372036854775807 START 150000000000001 CACHE 1 NO CYCLE),\n    \"uuid\" varchar(36) NOT NULL DEFAULT gen_random_uuid(),\n    \n    -- 1. BANK_CODE (e.g. 7339)\n    bank_code varchar(10) NOT NULL,\n    \n    -- 2. BANK_NAME (e.g. OCBC Bank)\n    bank_name varchar(40) NULL,\n    \n    -- 3. BANK_SHORTNAME (e.g. OCBCSGSG) - Note: This often acts as the BIC in legacy\n    bank_shortname varchar(15) NULL,\n    \n    -- 4. AUTODEBIT_INDICATOR (Y/N)\n    autodebit_indicator bpchar(1) NULL,\n    \n    -- 5. PARTICIPANT_INDICATOR (Y/N)\n    participant_indicator bpchar(1) NULL,\n    \n    -- Audit\n    \"version\" numeric(5) NOT NULL DEFAULT 1,\n    is_deleted bpchar(1) NOT NULL DEFAULT 'N'::bpchar,\n    is_migrated bpchar(1) NOT NULL DEFAULT 'N'::bpchar,\n    created_dt timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP,\n    created_by varchar(36) NOT NULL,\n    updated_dt timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP,\n    updated_by varchar(36) NOT NULL,\n    \n    CONSTRAINT cm_bank_master_bank_code_key UNIQUE (bank_code),\n    CONSTRAINT cm_bank_master_pkey PRIMARY KEY (id),\n    CONSTRAINT cm_bank_master_uuid_key UNIQUE (uuid)\n);\n\n-- History Table\nCREATE TABLE cm.cm_bank_master_t (\n    trans_id int8 NOT NULL GENERATED BY DEFAULT AS IDENTITY( INCREMENT BY 1 MINVALUE 1 MAXVALUE 9223372036854775807 START 150000000000001 CACHE 1 NO CYCLE),\n    trans_uuid varchar(36) NOT NULL DEFAULT gen_random_uuid(),\n    id int8 NOT NULL,\n    \"uuid\" varchar(36) NOT NULL,\n    \n    bank_code varchar(10) NOT NULL,\n    bank_name varchar(40) NULL,\n    bank_shortname varchar(15) NULL,\n    autodebit_indicator bpchar(1) NULL,\n    participant_indicator bpchar(1) NULL,\n    \n    \"version\" numeric(5) NOT NULL,\n    is_deleted bpchar(1) NOT NULL,\n    is_migrated bpchar(1) NOT NULL,\n    created_dt timestamp NOT NULL,\n    created_by varchar(36) NOT NULL,\n    updated_dt timestamp NOT NULL,\n    updated_by varchar(36) NOT NULL,\n    audit_action bpchar(1) NOT NULL,\n    audit_timestamp timestamp NULL DEFAULT CURRENT_TIMESTAMP,\n    is_history bpchar(1) NOT NULL DEFAULT 'Y'::bpchar,\n    \n    CONSTRAINT cm_bank_master_t_pkey PRIMARY KEY (trans_id),\n    CONSTRAINT cm_bank_master_t_trans_uuid_key UNIQUE (trans_uuid),\n    CONSTRAINT fk_bank_master_t_master FOREIGN KEY (\"uuid\") REFERENCES cm.cm_bank_master(\"uuid\")\n);\nCREATE INDEX idx_cm_bank_master_t_uuid ON cm.cm_bank_master_t USING btree (uuid);\n\n\n-- =========================================================================\n-- 2. CM_BANK_MASTER_MAP\n-- Purpose: Defines a \"Group\" of Banks (Used by Entities).\n-- =========================================================================\n\nCREATE TABLE cm.cm_bank_master_map (\n    id int8 NOT NULL GENERATED BY DEFAULT AS IDENTITY( INCREMENT BY 1 MINVALUE 1 MAXVALUE 9223372036854775807 START 150000000000001 CACHE 1 NO CYCLE),\n    \"uuid\" varchar(36) NOT NULL DEFAULT gen_random_uuid(),\n    \n    ref_id varchar(36) NOT NULL,\n    cm_bank_master_id varchar(36) NOT NULL,\n    \n    \"version\" numeric(5) NOT NULL DEFAULT 1,\n    is_deleted bpchar(1) NOT NULL DEFAULT 'N'::bpchar,\n    is_migrated bpchar(1) NOT NULL DEFAULT 'N'::bpchar,\n    created_dt timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP,\n    created_by varchar(36) NOT NULL,\n    updated_dt timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP,\n    updated_by varchar(36) NOT NULL,\n    \n    CONSTRAINT cm_bank_master_map_pkey PRIMARY KEY (id),\n    CONSTRAINT cm_bank_master_map_uuid_key UNIQUE (uuid),\n    CONSTRAINT cm_bank_map_unique_pair UNIQUE (ref_id, cm_bank_master_id)\n);\n\n-- History Table\nCREATE TABLE cm.cm_bank_master_map_t (\n    trans_id int8 NOT NULL GENERATED BY DEFAULT AS IDENTITY( INCREMENT BY 1 MINVALUE 1 MAXVALUE 9223372036854775807 START 150000000000001 CACHE 1 NO CYCLE),\n    trans_uuid varchar(36) NOT NULL DEFAULT gen_random_uuid(),\n    id int8 NOT NULL,\n    \"uuid\" varchar(36) NOT NULL,\n    \n    ref_id varchar(36) NOT NULL,\n    cm_bank_master_id varchar(36) NOT NULL,\n    \n    \"version\" numeric(5) NOT NULL,\n    is_deleted bpchar(1) NOT NULL,\n    is_migrated bpchar(1) NOT NULL,\n    created_dt timestamp NOT NULL,\n    created_by varchar(36) NOT NULL,\n    updated_dt timestamp NOT NULL,\n    updated_by varchar(36) NOT NULL,\n    audit_action bpchar(1) NOT NULL,\n    audit_timestamp timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP,\n    is_history bpchar(1) NOT NULL DEFAULT 'N'::bpchar,\n    \n    CONSTRAINT cm_bank_master_map_t_pkey PRIMARY KEY (trans_id),\n    CONSTRAINT cm_bank_master_map_t_trans_uuid_key UNIQUE (trans_uuid)\n);\nCREATE INDEX idx_cm_map_t_uuid ON cm.cm_bank_master_map_t USING btree (uuid);\n\n\n-- =========================================================================\n-- 3. CM_ORGANIZATION\n-- Purpose: Unified Entity & Counterparty Table.\n-- Structure: UUID -> Type -> [Entity Cols] -> [Counterparty Cols]\n-- =========================================================================\n\nCREATE TABLE cm.cm_organization (\n    id int8 NOT NULL GENERATED BY DEFAULT AS IDENTITY( INCREMENT BY 1 MINVALUE 1 MAXVALUE 9223372036854775807 START 150000000000001 CACHE 1 NO CYCLE),\n    \"uuid\" varchar(36) NOT NULL DEFAULT gen_random_uuid(),\n    \n    -- 1. Discriminator\n    org_type varchar(50) NOT NULL,          -- 'ENTITY' or 'COUNTERPARTY'\n    \n    -- 2. Shared Identity (Applicable to both)\n    org_name varchar(255) NOT NULL,         -- UI: \"Applicant name\" or \"Counterparty name\"\n    status varchar(50) NULL,                -- UI: \"Status\" (Active/Inactive)\n    remarks varchar(4000) NULL,             -- UI: \"Remarks (internal)\"\n    \n    -- 3. [ENTITY COLUMNS] (Used when org_type = 'ENTITY')\n    uen_no varchar(20) NULL,                -- UI: \"UEN\"\n    dealer_codes_ref_id varchar(36) NULL,   -- UI: \"Dealer codes\" (Links to Map)\n    entity_ref_doc_id varchar(36) NULL,     -- File Upload Traceability\n    \n    -- 4. [COUNTERPARTY COLUMNS] (Used when org_type = 'COUNTERPARTY')\n    cm_bank_master_uuid varchar(36) NULL,   -- Link to Source of Truth (Dealer Code)\n    org_short_name varchar(50) NULL,        -- UI: \"Short name\"\n    member_code varchar(20) NULL,           -- UI: \"BIC code\" (Matches UI req)\n    omnibus_acc_no varchar(34) NULL,        -- UI: \"Omnibus no.\"\n    custody_code varchar(3) NULL,           -- Default Custody\n    \n    -- Roles (UI: \"Role(s)\")\n    is_primary_dealer bpchar(1) NULL DEFAULT 'N'::bpchar,\n    is_mas_repo_eligible bpchar(1) NULL DEFAULT 'N'::bpchar,\n    is_mas_user bpchar(1) NULL DEFAULT 'N'::bpchar,\n    is_retail_pd boolean NULL DEFAULT false,\n    is_non_retail_pd boolean NULL DEFAULT false,\n    is_bd_bank boolean NULL DEFAULT false,\n    \n    -- Audit\n    \"version\" numeric(5) NOT NULL DEFAULT 1,\n    is_deleted bpchar(1) NOT NULL DEFAULT 'N'::bpchar,\n    is_migrated bpchar(1) NOT NULL DEFAULT 'N'::bpchar,\n    created_dt timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP,\n    created_by varchar(36) NOT NULL,\n    updated_dt timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP,\n    updated_by varchar(36) NOT NULL,\n    \n    CONSTRAINT cm_organization_pkey PRIMARY KEY (id),\n    CONSTRAINT cm_organization_uuid_key UNIQUE (uuid),\n    CONSTRAINT cm_org_bank_link_unique UNIQUE (cm_bank_master_uuid)\n);\n\n-- History Table\nCREATE TABLE cm.cm_organization_t (\n    trans_id int8 NOT NULL GENERATED BY DEFAULT AS IDENTITY( INCREMENT BY 1 MINVALUE 1 MAXVALUE 9223372036854775807 START 150000000000001 CACHE 1 NO CYCLE),\n    trans_uuid varchar(36) NOT NULL DEFAULT gen_random_uuid(),\n    id int8 NOT NULL,\n    \"uuid\" varchar(36) NOT NULL,\n    \n    org_type varchar(50) NOT NULL,\n    org_name varchar(255) NOT NULL,\n    status varchar(50) NULL,\n    remarks varchar(4000) NULL,\n    \n    -- Entity Cols\n    uen_no varchar(20) NULL,\n    dealer_codes_ref_id varchar(36) NULL,\n    entity_ref_doc_id varchar(36) NULL,\n    \n    -- Counterparty Cols\n    cm_bank_master_uuid varchar(36) NULL,\n    org_short_name varchar(50) NULL,\n    member_code varchar(20) NULL,\n    omnibus_acc_no varchar(34) NULL,\n    custody_code varchar(3) NULL,\n    \n    is_primary_dealer bpchar(1) NULL,\n    is_mas_repo_eligible bpchar(1) NULL,\n    is_mas_user bpchar(1) NULL,\n    is_retail_pd boolean NULL,\n    is_non_retail_pd boolean NULL,\n    is_bd_bank boolean NULL,\n    \n    \"version\" numeric(5) NOT NULL,\n    is_deleted bpchar(1) NOT NULL,\n    is_migrated bpchar(1) NOT NULL,\n    created_dt timestamp NOT NULL,\n    created_by varchar(36) NOT NULL,\n    updated_dt timestamp NOT NULL,\n    updated_by varchar(36) NOT NULL,\n    audit_action bpchar(1) NOT NULL,\n    audit_timestamp timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP,\n    is_history bpchar(1) NOT NULL DEFAULT 'N'::bpchar,\n    \n    CONSTRAINT cm_organization_t_pkey PRIMARY KEY (trans_id),\n    CONSTRAINT cm_organization_t_trans_uuid_key UNIQUE (trans_uuid)\n);\nCREATE INDEX idx_cm_organization_t_uuid ON cm.cm_organization_t USING btree (uuid);\n\n\n-- =========================================================================\n-- 4. FOREIGN KEYS & INDEXES\n-- =========================================================================\n\n-- CM_BANK_MASTER_MAP -> CM_BANK_MASTER\nALTER TABLE cm.cm_bank_master_map \n    ADD CONSTRAINT fk_bank_master_map_bank \n    FOREIGN KEY (cm_bank_master_id) \n    REFERENCES cm.cm_bank_master(\"uuid\");\n\n-- CM_ORGANIZATION -> CM_BANK_MASTER (Link for Counterparties)\nALTER TABLE cm.cm_organization \n    ADD CONSTRAINT fk_org_to_bank_master \n    FOREIGN KEY (cm_bank_master_uuid) \n    REFERENCES cm.cm_bank_master(\"uuid\");\n\n-- History Links\nALTER TABLE cm.cm_bank_master_t ADD CONSTRAINT fk_bank_t_master FOREIGN KEY (\"uuid\") REFERENCES cm.cm_bank_master(\"uuid\");\nALTER TABLE cm.cm_organization_t ADD CONSTRAINT fk_org_t_master FOREIGN KEY (\"uuid\") REFERENCES cm.cm_organization(\"uuid\");\nALTER TABLE cm.cm_bank_master_map_t ADD CONSTRAINT fk_bank_master_map_t_master FOREIGN KEY (\"uuid\") REFERENCES cm.cm_bank_master_map(\"uuid\");\n\n-- Indexes for performance\nCREATE INDEX idx_map_ref_id ON cm.cm_bank_master_map(ref_id);\nCREATE INDEX idx_org_dealer_codes ON cm.cm_organization(dealer_codes_ref_id);\nCREATE INDEX idx_org_uen ON cm.cm_organization(uen_no);\nCREATE INDEX idx_org_type ON cm.cm_organization(org_type);",
