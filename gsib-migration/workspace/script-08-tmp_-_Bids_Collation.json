  "rawContent": "-- ============================================================================\n-- 1. INSTITUTIONAL BIDS (Primary Dealers / Banks)\n-- ============================================================================\n\n-- iss.iss_bid_institutional definition\nCREATE TABLE iss.iss_bid_institutional (\n    id int8 NOT NULL GENERATED BY DEFAULT AS IDENTITY( INCREMENT BY 1 MINVALUE 1 MAXVALUE 9223372036854775807 START 150000000000001 CACHE 1 NO CYCLE),\n    \"uuid\" varchar(36) NOT NULL DEFAULT gen_random_uuid(),\n    \n    -- Relationships\n    iss_issuance_id varchar(36) NOT NULL, \n    cm_bank_master_map_id varchar(36) NOT NULL, \n    \n    -- Core Bid Data\n    bank_ref_no varchar(16) NOT NULL,     \n    applicant_type varchar(10) NOT NULL,  \n    applicant_name varchar(100) NOT NULL, \n    settlement_bank_code varchar(4) NOT NULL,\n    custody_code varchar(3) NOT NULL,     \n    \n    -- Economics\n    nominal_amount numeric(20, 2) NOT NULL, \n    allotted_amount numeric(20, 2) NULL,    \n    is_competitive bpchar(1) NOT NULL DEFAULT 'N'::bpchar, \n    yield_pct numeric(5, 2) NULL,         \n    price numeric(7, 4) NULL,             \n    \n    -- Workflow / System\n    submission_method varchar(20) NOT NULL, -- Ref: Master Code ISSSUBMTH\n    user_action varchar(50) NOT NULL,       -- Ref: Master Code USERACT (CREATE, UPDATE, WITHDRAW)\n    status varchar(50) NOT NULL,            -- Ref: Master Code ISSBIDSTAT\n    maker_remarks varchar(4000) NULL,\n    checker_remarks varchar(4000) NULL,\n    \n    -- Audit\n    \"version\" numeric(5) NOT NULL DEFAULT 1,\n    is_deleted bpchar(1) NOT NULL DEFAULT 'N'::bpchar,\n    is_migrated bpchar(1) NOT NULL DEFAULT 'N'::bpchar,\n    created_dt timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP,\n    created_by varchar(36) NOT NULL,\n    updated_dt timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP,\n    updated_by varchar(36) NOT NULL,\n\n    CONSTRAINT iss_bid_inst_pkey PRIMARY KEY (id),\n    CONSTRAINT iss_bid_inst_uuid_key UNIQUE (uuid),\n    CONSTRAINT iss_bid_inst_unique_ref UNIQUE (iss_issuance_id, cm_bank_master_map_id, bank_ref_no)\n);\n\nALTER TABLE iss.iss_bid_institutional ADD CONSTRAINT fk_bid_inst_issuance FOREIGN KEY (iss_issuance_id) REFERENCES iss.iss_issuance(\"uuid\");\nALTER TABLE iss.iss_bid_institutional ADD CONSTRAINT fk_bid_inst_pd_map FOREIGN KEY (cm_bank_master_map_id) REFERENCES cm.cm_bank_master_map(\"uuid\");\n\n-- iss.iss_bid_institutional_t definition (History)\nCREATE TABLE iss.iss_bid_institutional_t (\n    trans_id int8 NOT NULL GENERATED BY DEFAULT AS IDENTITY( INCREMENT BY 1 MINVALUE 1 MAXVALUE 9223372036854775807 START 150000000000001 CACHE 1 NO CYCLE),\n    trans_uuid varchar(36) NOT NULL DEFAULT gen_random_uuid(),\n    id int8 NOT NULL,\n    \"uuid\" varchar(36) NOT NULL,\n    \n    iss_issuance_id varchar(36) NULL,\n    cm_bank_master_map_id varchar(36) NULL,\n    bank_ref_no varchar(16) NULL,\n    applicant_type varchar(10) NULL,\n    applicant_name varchar(100) NULL,\n    settlement_bank_code varchar(4) NULL,\n    custody_code varchar(3) NULL,\n    \n    nominal_amount numeric(20, 2) NULL,\n    allotted_amount numeric(20, 2) NULL,\n    is_competitive bpchar(1) NULL,\n    yield_pct numeric(5, 2) NULL,\n    price numeric(7, 4) NULL,\n    \n    submission_method varchar(20) NULL,\n    user_action varchar(50) NULL, \n    status varchar(50) NULL,\n    maker_remarks varchar(4000) NULL,\n    checker_remarks varchar(4000) NULL,\n    \n    \"version\" numeric(5) NULL,\n    is_deleted bpchar(1) NOT NULL,\n    is_migrated bpchar(1) NOT NULL,\n    created_dt timestamp NOT NULL,\n    created_by varchar(36) NOT NULL,\n    updated_dt timestamp NOT NULL,\n    updated_by varchar(36) NOT NULL,\n    \n    audit_action bpchar(1) NOT NULL,\n    audit_timestamp timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP,\n    is_history bpchar(1) NOT NULL DEFAULT 'Y'::bpchar,\n    \n    CONSTRAINT iss_bid_inst_t_pkey PRIMARY KEY (trans_id),\n    CONSTRAINT iss_bid_inst_t_trans_uuid_key UNIQUE (trans_uuid)\n);\n\n-- ============================================================================\n-- 2. RETAIL BIDS (Individual Investors)\n-- ============================================================================\n\n-- iss.iss_bid_retail definition\nCREATE TABLE iss.iss_bid_retail (\n    id int8 NOT NULL GENERATED BY DEFAULT AS IDENTITY( INCREMENT BY 1 MINVALUE 1 MAXVALUE 9223372036854775807 START 150000000000001 CACHE 1 NO CYCLE),\n    \"uuid\" varchar(36) NOT NULL DEFAULT gen_random_uuid(),\n    \n    iss_issuance_id varchar(36) NOT NULL, \n    retail_bank_id varchar(36) NOT NULL,  \n    \n    bank_ref_no varchar(16) NOT NULL,     \n    nric_passport varchar(20) NOT NULL,   \n    applicant_name varchar(100) NOT NULL, \n    nationality_code varchar(2) NOT NULL, \n    \n    application_source varchar(10) NOT NULL, \n    cdp_account_no varchar(16) NULL,         \n    cpf_srs_account_no varchar(16) NULL,     \n    \n    nominal_amount numeric(20, 2) NOT NULL, \n    accepted_amount numeric(20, 2) NULL,    \n    allotted_amount numeric(20, 2) NULL,    \n    is_competitive bpchar(1) NOT NULL DEFAULT 'N'::bpchar,\n    yield_pct numeric(5, 2) NULL,\n    \n    submission_method varchar(20) NOT NULL, -- Ref: Master Code ISSSUBMTH\n    user_action varchar(50) NOT NULL,       -- Ref: Master Code USERACT\n    status varchar(50) NOT NULL,            -- Ref: Master Code ISSBIDSTAT\n    maker_remarks varchar(4000) NULL,\n    checker_remarks varchar(4000) NULL,\n    \n    \"version\" numeric(5) NOT NULL DEFAULT 1,\n    is_deleted bpchar(1) NOT NULL DEFAULT 'N'::bpchar,\n    is_migrated bpchar(1) NOT NULL DEFAULT 'N'::bpchar,\n    created_dt timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP,\n    created_by varchar(36) NOT NULL,\n    updated_dt timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP,\n    updated_by varchar(36) NOT NULL,\n\n    CONSTRAINT iss_bid_retail_pkey PRIMARY KEY (id),\n    CONSTRAINT iss_bid_retail_uuid_key UNIQUE (uuid),\n    CONSTRAINT iss_bid_retail_unique_ref UNIQUE (iss_issuance_id, retail_bank_id, bank_ref_no)\n);\n\nALTER TABLE iss.iss_bid_retail ADD CONSTRAINT fk_bid_retail_issuance FOREIGN KEY (iss_issuance_id) REFERENCES iss.iss_issuance(\"uuid\");\nALTER TABLE iss.iss_bid_retail ADD CONSTRAINT fk_bid_retail_bank FOREIGN KEY (retail_bank_id) REFERENCES cm.cm_bank_master(\"uuid\");\n\n-- iss.iss_bid_retail_t definition\nCREATE TABLE iss.iss_bid_retail_t (\n    trans_id int8 NOT NULL GENERATED BY DEFAULT AS IDENTITY( INCREMENT BY 1 MINVALUE 1 MAXVALUE 9223372036854775807 START 150000000000001 CACHE 1 NO CYCLE),\n    trans_uuid varchar(36) NOT NULL DEFAULT gen_random_uuid(),\n    id int8 NOT NULL,\n    \"uuid\" varchar(36) NOT NULL,\n    \n    iss_issuance_id varchar(36) NULL,\n    retail_bank_id varchar(36) NULL,\n    bank_ref_no varchar(16) NULL,\n    nric_passport varchar(20) NULL,\n    applicant_name varchar(100) NULL,\n    nationality_code varchar(2) NULL,\n    application_source varchar(10) NULL,\n    cdp_account_no varchar(16) NULL,\n    cpf_srs_account_no varchar(16) NULL,\n    \n    nominal_amount numeric(20, 2) NULL,\n    accepted_amount numeric(20, 2) NULL, \n    allotted_amount numeric(20, 2) NULL,\n    is_competitive bpchar(1) NULL,\n    yield_pct numeric(5, 2) NULL,\n    \n    submission_method varchar(20) NULL,\n    user_action varchar(50) NULL, \n    status varchar(50) NULL,\n    maker_remarks varchar(4000) NULL,\n    checker_remarks varchar(4000) NULL,\n    \n    \"version\" numeric(5) NULL,\n    is_deleted bpchar(1) NOT NULL,\n    is_migrated bpchar(1) NOT NULL,\n    created_dt timestamp NOT NULL,\n    created_by varchar(36) NOT NULL,\n    updated_dt timestamp NOT NULL,\n    updated_by varchar(36) NOT NULL,\n    \n    audit_action bpchar(1) NOT NULL,\n    audit_timestamp timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP,\n    is_history bpchar(1) NOT NULL DEFAULT 'Y'::bpchar,\n    \n    CONSTRAINT iss_bid_retail_t_pkey PRIMARY KEY (trans_id),\n    CONSTRAINT iss_bid_retail_t_trans_uuid_key UNIQUE (trans_uuid)\n);\n\n-- ============================================================================\n-- 3. FILE REGISTRY\n-- ============================================================================\n\n-- iss.iss_bid_file_registry definition\nCREATE TABLE iss.iss_bid_file_registry (\n    id int8 NOT NULL GENERATED BY DEFAULT AS IDENTITY( INCREMENT BY 1 MINVALUE 1 MAXVALUE 9223372036854775807 START 150000000000001 CACHE 1 NO CYCLE),\n    \"uuid\" varchar(36) NOT NULL DEFAULT gen_random_uuid(),\n    \n    iss_issuance_id varchar(36) NOT NULL,\n    cm_documents_uuid varchar(36) NOT NULL, \n    \n    file_type varchar(50) NOT NULL, -- Ref: Master Code BIDFTYPE\n    total_records numeric(10) NOT NULL DEFAULT 0,\n    successful_records numeric(10) NOT NULL DEFAULT 0,\n    failed_records numeric(10) NOT NULL DEFAULT 0,\n    \n    \"version\" numeric(5) NOT NULL DEFAULT 1,\n    is_deleted bpchar(1) NOT NULL DEFAULT 'N'::bpchar,\n    is_migrated bpchar(1) NOT NULL DEFAULT 'N'::bpchar,\n    created_dt timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP,\n    created_by varchar(36) NOT NULL,\n    updated_dt timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP,\n    updated_by varchar(36) NOT NULL,\n\n    CONSTRAINT iss_bid_file_reg_pkey PRIMARY KEY (id),\n    CONSTRAINT iss_bid_file_reg_uuid_key UNIQUE (uuid)\n);\n\nALTER TABLE iss.iss_bid_file_registry ADD CONSTRAINT fk_bid_file_issuance FOREIGN KEY (iss_issuance_id) REFERENCES iss.iss_issuance(\"uuid\");\nALTER TABLE iss.iss_bid_file_registry ADD CONSTRAINT fk_bid_file_doc FOREIGN KEY (cm_documents_uuid) REFERENCES cm.cm_documents(\"uuid\");  \n\n-- iss.iss_bid_file_registry_t definition\nCREATE TABLE iss.iss_bid_file_registry_t (\n    trans_id int8 NOT NULL GENERATED BY DEFAULT AS IDENTITY( INCREMENT BY 1 MINVALUE 1 MAXVALUE 9223372036854775807 START 150000000000001 CACHE 1 NO CYCLE),\n    trans_uuid varchar(36) NOT NULL DEFAULT gen_random_uuid(),\n    id int8 NOT NULL,\n    \"uuid\" varchar(36) NOT NULL,\n    \n    iss_issuance_id varchar(36) NULL,\n    cm_documents_uuid varchar(36) NULL,\n    \n    file_type varchar(50) NULL,\n    total_records numeric(10) NULL,\n    successful_records numeric(10) NULL,\n    failed_records numeric(10) NULL,\n    \n    \"version\" numeric(5) NULL,\n    is_deleted bpchar(1) NOT NULL,\n    is_migrated bpchar(1) NOT NULL,\n    created_dt timestamp NOT NULL,\n    created_by varchar(36) NOT NULL,\n    updated_dt timestamp NOT NULL,\n    updated_by varchar(36) NOT NULL,\n    \n    audit_action bpchar(1) NOT NULL,\n    audit_timestamp timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP,\n    is_history bpchar(1) NOT NULL DEFAULT 'Y'::bpchar,\n    \n    CONSTRAINT iss_bid_file_reg_t_pkey PRIMARY KEY (trans_id),\n    CONSTRAINT iss_bid_file_reg_t_trans_uuid_key UNIQUE (trans_uuid)\n);",
