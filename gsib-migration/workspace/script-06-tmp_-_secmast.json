  "rawContent": "-- iss.iss_issuance_t definition\n\n-- Drop table\n\n-- DROP TABLE iss.iss_issuance_t;\n\nCREATE TABLE iss.iss_issuance_t (\n\ttrans_id int8 NOT NULL GENERATED BY DEFAULT AS IDENTITY( INCREMENT BY 1 MINVALUE 1 MAXVALUE 9223372036854775807 START 150000000000001 CACHE 1 NO CYCLE),\n\ttrans_uuid varchar(36) NOT NULL DEFAULT gen_random_uuid(),\n\tid int8 NOT NULL,\n\t\"uuid\" varchar(36) NOT NULL,\n\tsec_security_master_id varchar(36) NOT NULL,\n\tissue_no numeric(3) NOT NULL,\n\tissuance_type varchar(15) NOT NULL,\n\tannouncement_dt timestamp NOT NULL,\n\tauction_dt timestamp NOT NULL,\n\tissue_dt timestamp NOT NULL,\n\ttenor numeric(3) NOT NULL,\n\ttenor_unit bpchar(1) NOT NULL,\n\tcoupon_rate_pct numeric(7, 4) NOT NULL,\n\tlast_int_date timestamp NULL,\n\tex_int_date timestamp NULL,\n\tint_paid_ind bpchar(1) NOT NULL,\n\tcpn_paym_ind bpchar(1) NOT NULL,\n\tnext_int_date timestamp NOT NULL,\n\tdenomination numeric(10) NOT NULL,\n\tnew_reopen_flag bpchar(1) NOT NULL,\n\tissue_type varchar(20) NOT NULL,\n\tpricing_dt timestamp NULL,\n\tpublic_offer_start_dt timestamp NULL,\n\tpublic_offer_end_dt timestamp NULL,\n\tapp_closing_dt timestamp NOT NULL,\n\tis_benchmark bpchar(1) NOT NULL,\n\topen_dt timestamp NULL,\n\tclose_dt timestamp NULL,\n\t\"version\" numeric(5) NOT NULL,\n\tis_deleted bpchar(1) NOT NULL,\n\tis_migrated bpchar(1) NOT NULL,\n\tcreated_dt timestamp NOT NULL,\n\tcreated_by varchar(36) NOT NULL,\n\tupdated_dt timestamp NOT NULL,\n\tupdated_by varchar(36) NOT NULL,\n\taudit_action bpchar(1) NOT NULL,\n\taudit_timestamp timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP,\n\tis_history bpchar(1) NOT NULL DEFAULT 'Y'::bpchar,\n\tCONSTRAINT iss_issuance_h_hist_uuid_key UNIQUE (trans_uuid),\n\tCONSTRAINT iss_issuance_h_pkey PRIMARY KEY (trans_id)\n);\n\n\n-- iss.iss_issuance definition\n\n-- Drop table\n\n-- DROP TABLE iss.iss_issuance;\n\nCREATE TABLE iss.iss_issuance (\n\tid int8 NOT NULL GENERATED BY DEFAULT AS IDENTITY( INCREMENT BY 1 MINVALUE 1 MAXVALUE 9223372036854775807 START 150000000000001 CACHE 1 NO CYCLE),\n\t\"uuid\" varchar(36) NOT NULL DEFAULT gen_random_uuid(),\n\tsec_security_master_id varchar(36) NOT NULL,\n\tissue_no numeric(3) NOT NULL,\n\tissuance_type varchar(15) NOT NULL,\n\tannouncement_dt timestamp NOT NULL,\n\tauction_dt timestamp NOT NULL,\n\tissue_dt timestamp NOT NULL,\n\ttenor numeric(3) NOT NULL,\n\ttenor_unit bpchar(1) NOT NULL,\n\tcoupon_rate_pct numeric(7, 4) NOT NULL,\n\tlast_int_date timestamp NULL,\n\tex_int_date timestamp NULL,\n\tint_paid_ind bpchar(1) NOT NULL,\n\tcpn_paym_ind bpchar(1) NOT NULL,\n\tnext_int_date timestamp NOT NULL,\n\tdenomination numeric(10) NOT NULL,\n\tnew_reopen_flag bpchar(1) NOT NULL,\n\tissue_type varchar(20) NOT NULL,\n\tpricing_dt timestamp NULL,\n\tpublic_offer_start_dt timestamp NULL,\n\tpublic_offer_end_dt timestamp NULL,\n\tapp_closing_dt timestamp NOT NULL,\n\tis_benchmark bpchar(1) NOT NULL,\n\topen_dt timestamp NULL,\n\tclose_dt timestamp NULL,\n\t\"version\" numeric(5) NOT NULL,\n\tis_deleted bpchar(1) NOT NULL,\n\tis_migrated bpchar(1) NOT NULL,\n\tcreated_dt timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP,\n\tcreated_by varchar(36) NOT NULL,\n\tupdated_dt timestamp NOT NULL,\n\tupdated_by varchar(36) NOT NULL,\n\tCONSTRAINT iss_issuance_pkey PRIMARY KEY (id),\n\tCONSTRAINT iss_issuance_uuid_key UNIQUE (uuid)\n);\n\n\n-- iss.iss_issuance foreign keys\n\nALTER TABLE iss.iss_issuance ADD CONSTRAINT fk_issuance_security_master FOREIGN KEY (sec_security_master_id) REFERENCES sec.sec_security_master(\"uuid\");",
